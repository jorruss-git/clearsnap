---
interface Props {
  /** Unique AdSense slot ID for this placement. Get from AdSense dashboard. */
  slotId: string;
}

const { slotId } = Astro.props;
---

<div class="ad-slot" aria-label="Advertisement">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-8520557798047334"
    data-ad-slot={slotId}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>
